<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="RibbonOnLoad"
          loadImage="LoadImage">
  <ribbon>
    <tabs>
      <tab id="OneMarkDotNetTab" label="OneMarkDotNet">
        <group id="OneMarkGroup" label="OneMark" autoScale="true">
          <button id="btnRenderMarkdown"
                  label="Render Markdown"
                  screentip="Render current selection or pasted Markdown (F5)"
                  onAction="OnRenderMarkdown"
                  imageMso="ReviewAcceptChange"
                  size="large" />
          <button id="btnExportMarkdown"
                  label="Export Markdown"
                  screentip="Export current page as Markdown (F8)"
                  onAction="OnExportMarkdown"
                  imageMso="FileSaveAs"
                  size="large" />
          <button id="btnSourceModeToggle"
                  label="Source Mode"
                  screentip="Toggle source/rendered mode (Ctrl+,)"
                  onAction="OnSourceModeToggle"
                  imageMso="DesignMode"
                  size="large" />
          <separator id="sep1" />
          <menu id="menuTheme"
                label="Theme"
                imageMso="ThemeFonts"
                size="large">
            <dynamicMenu id="dynThemeMenu"
                         label="Select Theme"
                         getContent="GetThemeMenuContent" />
            <button id="btnOpenThemeDir"
                    label="Open Theme Directory"
                    onAction="OnOpenThemeDirectory" />
            <button id="btnReloadThemes"
                    label="Reload Themes"
                    onAction="OnReloadThemes" />
          </menu>
          <separator id="sep2" />
          <button id="btnImportMarkdown"
                  label="Import Markdown"
                  screentip="Import Markdown file"
                  onAction="OnImportMarkdown"
                  imageMso="FileOpen"
                  size="large" />
          <button id="btnExportMarkdownFile"
                  label="Export to File"
                  screentip="Export current page to Markdown file"
                  onAction="OnExportMarkdownFile"
                  imageMso="FileSave"
                  size="large" />
          <separator id="sep3" />
          <button id="btnAbout"
                  label="About"
                  onAction="OnAbout"
                  imageMso="Help"
                  size="large" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
