  <!-- 构建后自动注册 COM Add-In（需要以管理员身份运行 Visual Studio） -->
  <Target Name="PostBuildRegAsm" AfterTargets="Build" Condition="'$(PostBuildRegAsm)' != 'false'">
    <PropertyGroup>
      <RegAsmPath>C:\Windows\Microsoft.NET\Framework64\v4.0.30319\RegAsm.exe</RegAsmPath>
      <DllPath>$(TargetPath)</DllPath>
    </PropertyGroup>
    <Exec Command="&quot;$(RegAsmPath)&quot; /codebase &quot;$(DllPath)&quot;"
          Condition="Exists('$(RegAsmPath)')"
          IgnoreExitCode="true"
          ConsoleToMSBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="RegAsmOutput" />
    </Exec>
    <Message Importance="high" Text="RegAsm: $(RegAsmOutput)" Condition="Exists('$(RegAsmPath)')" />
    <Message Importance="high" Text="警告: RegAsm.exe 未找到，请手动注册 COM Add-In" Condition="!Exists('$(RegAsmPath)')" />
  </Target>

  <!-- 构建后自动注册 OneNote Add-In 注册表条目 -->
  <Target Name="PostBuildRegisterAddIn" AfterTargets="PostBuildRegAsm" Condition="'$(PostBuildRegAsm)' != 'false'">
    <Exec Command="reg add &quot;HKCU\Software\Microsoft\Office\OneNote\AddIns\NoteMark.AddIn&quot; /v FriendlyName /d NoteMark /f"
          IgnoreExitCode="true" ConsoleToMSBuild="true" />
    <Exec Command="reg add &quot;HKCU\Software\Microsoft\Office\OneNote\AddIns\NoteMark.AddIn&quot; /v Description /d &quot;OneNote Markdown Extension&quot; /f"
          IgnoreExitCode="true" ConsoleToMSBuild="true" />
    <Exec Command="reg add &quot;HKCU\Software\Microsoft\Office\OneNote\AddIns\NoteMark.AddIn&quot; /v LoadBehavior /t REG_DWORD /d 3 /f"
          IgnoreExitCode="true" ConsoleToMSBuild="true" />
    <Message Importance="high" Text="OneNote Add-In 注册表条目已创建" />
  </Target>
